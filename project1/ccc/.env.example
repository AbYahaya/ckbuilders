# nervos dao script metadata for your dev chain
DAO_CODE_HASH=0x82d76d1b75fe2fd9a27dfbaa65a039221a380d76c926f378d3f81cf3e7e13f2e
DAO_HASH_TYPE=type
DAO_DEP_TX_HASH=0x1bb87da347a776a927ab6593e1e10304ca195f8e24279f039008d5e3115b1bf7
