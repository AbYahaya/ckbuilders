SECP_EXEC_TX_HASH=0x1bb87da347a776a927ab6593e1e10304ca195f8e24279f039008d5e3115b1bf7
SECP_EXEC_INDEX_A=0x3
SECP_EXEC_INDEX_B=0x1

# anyone-can-pay script metadata for your dev chain
ACP_CODE_HASH=0xe09352af0066f3162287763ce4ddba9af6bfaeab198dc7ab37f8c71c9e68bb5b
ACP_HASH_TYPE=type
ACP_DEP_TX_HASH=0x1bb87da347a776a927ab6593e1e10304ca195f8e24279f039008d5e3115b1bf7
ACP_DEP_INDEX=0x8
